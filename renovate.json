{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group Deno runtime references",
      "matchDatasources": [
        "docker",
        "github-releases"
      ],
      "matchPackageNames": [
        "denoland/deno",
        "denoland/setup-deno"
      ],
      "groupName": "Deno"
    }
  ]
}
