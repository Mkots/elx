amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"

local linters = new Mapping<String, Step> {
    ["fmt"] {
        glob = List("*.ts", "*.tsx", "*.js", "*.jsx", "*.json", "*.md")
        check = "deno fmt --check {{files}}"
        fix = "deno fmt {{files}}"
    }
    ["lint"] {
        glob = List("*.ts", "*.tsx", "*.js", "*.jsx")
        // Mirror deno.json `lint.exclude`: `deno lint` errors with
        // "No target files found" when every path it is handed is excluded, so
        // hk must drop those files before substituting {{files}} (otherwise a
        // commit touching only excluded paths like `.agents/skills` fails).
        exclude = List(
            "coverage/**",
            ".wiki-build/**",
            "node_modules/**",
            "playwright-report/**",
            "test-results/**",
            "static/**",
            ".agents/skills/**",
        )
        check = "deno lint {{files}}"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = linters
    }
    ["pre-push"] {
        steps {
            ["check"] {
                check = "deno task check"
            }
            ["test"] {
                // hk runs pre-push steps concurrently. `deno test` type-checks by
                // default, so running it alongside `check` type-checks the whole
                // graph twice at once and oversubscribes the CPU (~9s). The
                // `check` step already owns whole-project type-checking, so run
                // tests here with --no-check (still --parallel) — ~2.6s.
                check =
                    "deno test --no-check --parallel --allow-env --allow-read --allow-write --allow-net"
            }
        }
    }
}
