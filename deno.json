{
  "name": "elx",
  "version": "0.1.0",
  "exports": "./main.ts",
  "nodeModulesDir": "auto",
  "exclude": [
    ".deno-cache",
    ".claude"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "strict": true
  },
  "fmt": {
    "exclude": [
      "coverage",
      ".wiki-build",
      "node_modules",
      "playwright-report",
      "test-results",
      "static"
    ]
  },
  "lint": {
    "exclude": [
      "coverage",
      ".wiki-build",
      "node_modules",
      "playwright-report",
      "test-results",
      "static"
    ]
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@4.12.24",
    "@playwright/test": "npm:@playwright/test@1.61.0",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/cli/parse-args": "jsr:@std/cli@1.0.21/parse-args",
    "@std/csv": "jsr:@std/csv@1.0.2",
    "@std/front-matter": "jsr:@std/front-matter@1.0.9",
    "drizzle-kit": "npm:drizzle-kit@0.31.10",
    "drizzle-orm": "npm:drizzle-orm@0.45.2",
    "drizzle-orm/": "npm:/drizzle-orm@0.45.2/",
    "hono": "jsr:@hono/hono@4.12.24",
    "hono/": "jsr:/@hono/hono@4.12.24/",
    "playwright": "npm:playwright@1.61.0",
    "postgres": "npm:postgres@3.4.9"
  },
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --allow-read=static,.env --allow-write=.data main.ts",
    "start": "deno run --allow-net --allow-env --allow-read=/app/static,/app/.env --allow-write=.data main.ts",
    "start:e2e": "deno run --allow-net --allow-env --allow-read=static,.env --allow-write=.data main.ts",
    "check": "deno check .",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "test": "deno test --allow-env --allow-read --allow-write --allow-net",
    "test:coverage": "DENO_DIR=.deno-cache deno test --clean --coverage=coverage --coverage-raw-data-only --allow-env --allow-read --allow-write --allow-net && DENO_DIR=.deno-cache deno coverage coverage --lcov --output=coverage.lcov",
    "wiki:build": "deno run -A scripts/build_wiki.ts docs .wiki-build",
    "seed:e2e": "deno task db:migrate && deno task seed:words && deno task seed:ticket",
    "seed:words": "deno run --allow-net --allow-env --allow-read=.env scripts/seed_words.ts",
    "seed:ticket": "deno run --allow-net --allow-env --allow-read=.env scripts/seed_ticket.ts",
    "import:words": "deno run --allow-net --allow-env --allow-read scripts/import_words.ts",
    "clean": "deno run --allow-read --allow-write scripts/clean.ts",
    "enrich": "deno run --allow-read --allow-write scripts/enrich.ts --format csv",
    "db:generate": "deno run -A npm:drizzle-kit@0.31.10 generate",
    "db:migrate": "deno run -A npm:drizzle-kit@0.31.10 migrate",
    "e2e": "deno run -A npm:@playwright/test@1.61.0 test",
    "ci": "deno task fmt:check && deno task lint && deno task check && deno task test:coverage"
  },
  "lock": {
    "frozen": true
  }
}
