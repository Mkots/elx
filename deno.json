{
  "name": "elx",
  "version": "0.1.0",
  "exports": "./main.ts",
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "strict": true
  },
  "fmt": {
    "exclude": [
      "coverage",
      ".wiki-build",
      "node_modules",
      "playwright-report",
      "test-results",
      "static"
    ]
  },
  "lint": {
    "exclude": [
      "coverage",
      ".wiki-build",
      "node_modules",
      "playwright-report",
      "test-results",
      "static"
    ]
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@4.12.24",
    "@playwright/test": "npm:@playwright/test@1.61.0",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/cli/parse-args": "jsr:@std/cli@1.0.21/parse-args",
    "@std/front-matter": "jsr:@std/front-matter@1.0.9",
    "drizzle-kit": "npm:drizzle-kit@0.31.10",
    "drizzle-orm": "npm:drizzle-orm@0.45.2",
    "drizzle-orm/": "npm:/drizzle-orm@0.45.2/",
    "hono": "jsr:@hono/hono@4.12.24",
    "hono/": "jsr:/@hono/hono@4.12.24/",
    "playwright": "npm:playwright@1.61.0",
    "postgres": "npm:postgres@3.4.9"
  },
  "tasks": {
    "dev": "deno run --watch --unstable-kv --allow-net --allow-env --allow-read=static,.data,/data/kv --allow-write=.data,/data/kv main.ts",
    "start": "deno run --unstable-kv --allow-net --allow-env --allow-read=static,/data/kv --allow-write=/data/kv main.ts",
    "start:e2e": "deno run --unstable-kv --allow-net --allow-env --allow-read=static,.data --allow-write=.data main.ts",
    "check": "deno check main.ts app.ts session.ts deps.ts drizzle.config.ts playwright.config.ts routes/*.ts routes/*.tsx ui/components/*.tsx ui/pages/*.tsx db/*.ts scripts/*.ts scoring/*.ts tests/*.ts tests/e2e/*.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "test": "deno test --allow-env --unstable-kv --allow-read --allow-write",
    "test:coverage": "DENO_DIR=.deno-cache deno test --clean --coverage=coverage --coverage-raw-data-only --allow-env --unstable-kv --allow-read --allow-write && DENO_DIR=.deno-cache deno coverage coverage --lcov --output=coverage.lcov",
    "wiki:build": "deno run -A scripts/build_wiki.ts docs .wiki-build",
    "seed:e2e": "deno task db:migrate && deno task seed:words",
    "seed:words": "deno run --allow-net --allow-env scripts/seed_words.ts",
    "seed:synonyms": "deno run --allow-net --allow-env scripts/seed_synonyms.ts",
    "seed:spelling": "deno run --allow-net --allow-env scripts/seed_spelling.ts",
    "seed:meanings": "deno run --allow-net --allow-env scripts/seed_meanings.ts",
    "db:generate": "deno run -A npm:drizzle-kit@0.31.10 generate",
    "db:migrate": "deno run -A npm:drizzle-kit@0.31.10 migrate",
    "e2e": "deno run -A npm:@playwright/test@1.61.0 test",
    "ci": "deno task fmt:check && deno task lint && deno task check && deno task test:coverage"
  },
  "lock": {
    "frozen": true
  }
}
