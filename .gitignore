# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.*
!.env.example

# Deno
.deno-cache/

# Build artifacts
.wiki-build/
coverage/
coverage.lcov

# Docker data
.data/

# Test artifacts
playwright-report/
test-results/

# Dependencies
node_modules/

# Editor / AI
*.swp
*.swo
*~
.vscode/settings.json
.agents/skills/gh-issue-solver/state.json

# Generated pipeline artifacts (see pipeline/README.md); manifest.json is the
# one file in here that stays committed for provenance.
pipeline/out/*
!pipeline/out/manifest.json

# Raw pipeline data: tracked for sources that are small and license-clean
# (subtlex, tatoeba, seed_words.csv); wordlists/wordnet are large/local-only,
# README only.
pipeline/data/*
!pipeline/data/seed_words.csv
!pipeline/data/tatoeba/
!pipeline/data/tatoeba/eng_sentences_filtered.tsv
!pipeline/data/tatoeba/README.md
!pipeline/data/subtlex/
!pipeline/data/subtlex/README.md
!pipeline/data/wordlists/
pipeline/data/wordlists/*
!pipeline/data/wordlists/README.md
!pipeline/data/wordnet/
pipeline/data/wordnet/*
!pipeline/data/wordnet/README.md
pipeline/out/manifest.json
