{
  "name": "ELX Deno",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/deno:2": {
      "version": "2.8.3"
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "containerEnv": {
    "DATABASE_URL": "postgres://elx:elx@host.docker.internal:5432/elx"
  },
  "forwardPorts": [
    8000,
    5432
  ],
  "portsAttributes": {
    "8000": {
      "label": "ELX web"
    },
    "5432": {
      "label": "PostgreSQL"
    }
  },
  "postCreateCommand": "test -f .env || cp .env.example .env; deno install --frozen",
  "remoteUser": "vscode"
}
