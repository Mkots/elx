.git
.github
.agents
.claude
.devcontainer
.zed
.editorconfig
.gitignore
.dockerignore
Dockerfile
hk.pkl
sara.toml

# Docs & repo meta (never read at runtime)
docs
deploy
AGENTS.md
CLAUDE.md
README.md
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md

# Orchestration configs (deploy copies compose.yaml from the checkout, not the image)
compose.yaml
compose.dev.yaml

# Tests & QA artifacts
tests
playwright.config.ts
playwright-report
test-results
coverage
coverage.lcov

# Local caches / state / build artifacts
.deno-cache
.data
.wiki-build
node_modules
**/.DS_Store

# Secrets
.env
.env.*
!.env.example

# Offline word pipeline: exclude the heavy raw/generated data (~79 MB) but
# keep the TS sources — the runtime module graph needs them
# (domain/ticket_generation.ts imports pipeline/phonetic_distractors.ts), and
# `deno task seed:words` (run in-container via seed.yaml) reads seed_words.csv.
pipeline/data/*
!pipeline/data/seed_words.csv
pipeline/out
pipeline/notes
pipeline/testdata
